@model hifiDomain.Model.Internalpartsbrand
@{
    ViewData["Title"] = "Деталі компонента";
}

<div class="max-w-md space-y-6">
    <div class="flex items-center justify-between">
        <h1 class="text-2xl font-bold">@Model.Name</h1>
            <a asp-controller="Home" asp-action="Index" class="text-sm text-muted-foreground hover:text-foreground">← Назад</a>
    </div>
    <div class="rounded-lg border bg-card p-6">
        <div class="grid grid-cols-2 gap-3 text-sm">
            <span class="text-muted-foreground">Назва</span><span class="font-medium">@Model.Name</span>
            <span class="text-muted-foreground">Опис</span><span>@Model.Description</span>
            <span class="text-muted-foreground">Країна</span><span>@Model.Country</span>
        </div>
    </div>
    
</div>
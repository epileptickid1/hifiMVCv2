@model hifiDomain.Model.Order
@{
    ViewData["Title"] = "Редагувати замовлення";
}

<div class="max-w-md space-y-6">
    <div class="flex items-center justify-between">
        <h1 class="text-2xl font-bold">Редагувати замовлення</h1>
        <a asp-action="Index" class="text-sm text-muted-foreground hover:text-foreground">← Назад</a>
    </div>
    <div class="rounded-lg border bg-card p-6">
        <form asp-action="Edit" class="space-y-4">
            <div asp-validation-summary="ModelOnly" class="text-destructive text-sm"></div>
            <input type="hidden" asp-for="Id" />
            <div class="space-y-1">
                <label asp-for="Orderdate" class="text-sm font-medium"></label>
                <input asp-for="Orderdate" class="flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-sm focus:outline-none focus:ring-1 focus:ring-ring" />
            </div>
            <div class="space-y-1">
                <label asp-for="Totalamount" class="text-sm font-medium"></label>
                <input asp-for="Totalamount" class="flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-sm focus:outline-none focus:ring-1 focus:ring-ring" />
            </div>
            <div class="space-y-1">
                <label asp-for="Customerid" class="text-sm font-medium"></label>
                <select asp-for="Customerid" asp-items="ViewBag.Customerid"
                        class="flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-sm focus:outline-none focus:ring-1 focus:ring-ring"></select>
            </div>
            <div class="space-y-1">
                <label asp-for="Quantity" class="text-sm font-medium"></label>
                <input asp-for="Quantity" class="flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-sm focus:outline-none focus:ring-1 focus:ring-ring" />
            </div>
            <button type="submit"
                    class="w-full inline-flex justify-center rounded-md bg-blue-800 px-4 py-2 text-sm font-medium text-primary-foreground hover:bg-blue-600 transition-colors">
                Зберегти
            </button>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}
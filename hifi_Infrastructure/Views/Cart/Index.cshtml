@model IEnumerable<hifiDomain.Model.Headphone>

@{
    ViewData["Title"] = "Cart";
}

<div class="container mt-4">
    <h2> Your Cart</h2>

    @if (!Model.Any())
    {
        <p>Your cart is empty. <a asp-controller="Home" asp-action="Index">Continue shopping</a></p>
    }
    else
    {
        <table class="table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Price</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Name</td>
                        <td>@item.Price ₴</td>
                        <td>
                            <a asp-action="Remove" asp-route-id="@item.Id"
                               class="btn btn-danger btn-sm">Remove</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <p><strong>Total: @Model.Sum(h => h.Price ?? 0) ₴</strong></p>
        <a asp-action="Checkout" class="btn btn-success">Place Order</a>
    }
</div>
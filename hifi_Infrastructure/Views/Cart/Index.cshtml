@model IEnumerable<hifiDomain.Model.Headphone>
@{
    ViewData["Title"] = "Кошик";
    var quantities = ViewBag.Quantities as Dictionary<int, int> ?? new Dictionary<int, int>();
    decimal total = Model.Sum(h => (h.Price ?? 0) * (quantities.ContainsKey(h.Id) ? quantities[h.Id] : 1));
}

<div class="max-w-2xl space-y-6">
    <h1 class="text-2xl font-bold">Кошик</h1>

    @if (!Model.Any())
    {
        <div class="rounded-lg border bg-card p-10 text-center space-y-3">
            <p class="text-muted-foreground">Кошик порожній</p>
            <a asp-controller="Home" asp-action="Index"
                   class="inline-flex items-center justify-center rounded-md bg-slate-900 px-4 py-2 text-sm font-medium text-white hover:bg-slate-700 transition-colors">
                Продовжити покупки
            </a>
        </div>
    }
    else
    {
        <div class="rounded-lg border bg-card overflow-hidden">
            <table class="w-full text-sm">
                <thead class="border-b bg-muted/50">
                    <tr>
                        <th class="px-4 py-3 text-left font-medium">Назва</th>
                        <th class="px-4 py-3 text-left font-medium">Ціна</th>
                        <th class="px-4 py-3 text-left font-medium">Кількість</th>
                        <th class="px-4 py-3 text-left font-medium">Сума</th>
                        <th class="px-4 py-3"></th>
                    </tr>
                </thead>
                <tbody class="divide-y">
                    @foreach (var item in Model)
                    {
                        var qty = quantities.ContainsKey(item.Id) ? quantities[item.Id] : 1;
                        <tr class="hover:bg-muted/30 transition-colors">
                            <td class="px-4 py-3 font-medium">@item.Name</td>
                            <td class="px-4 py-3">@item.Price ₴</td>
                            <td class="px-4 py-3">
                                <form method="get" asp-controller="Cart" asp-action="UpdateQuantity" class="flex items-center gap-1">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <input type="number" name="quantity" value="@qty" min="1"
                                           class="w-16 rounded-md border border-input bg-transparent px-2 py-1 text-sm text-center focus:outline-none focus:ring-1 focus:ring-ring" />
                                    <button type="submit"
                                            class="text-xs px-2 py-1 rounded border hover:bg-accent transition-colors">
                                        submit
                                    </button>
                                </form>
                            </td>
                            <td class="px-4 py-3 font-semibold">@((item.Price ?? 0) * qty) ₴</td>
                            <td class="px-4 py-3 text-right">
                                <a asp-action="Remove" asp-route-id="@item.Id"
                                       class="text-xs px-2 py-1 rounded border border-destructive/50 text-destructive hover:bg-destructive/10 transition-colors">
                                    Видалити
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot class="border-t bg-muted/30">
                    <tr>
                        <td colspan="3" class="px-4 py-3 text-right font-medium">Разом:</td>
                        <td class="px-4 py-3 font-bold text-base">@total ₴</td>
                        <td></td>
                    </tr>
                </tfoot>
            </table>
        </div>

        <div class="flex gap-3">
            <a asp-controller="Home" asp-action="Index"
                   class="inline-flex items-center justify-center rounded-md border px-4 py-2 text-sm font-medium hover:bg-accent transition-colors">
                 Продовжити покупки
            </a>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a asp-action="Checkout"
                       class="inline-flex items-center justify-center rounded-md bg-slate-900 px-4 py-2 text-sm font-medium text-white hover:bg-slate-700 transition-colors">
                    Оформити замовлення 
                </a>
            }
            else
            {
                <a asp-controller="Account" asp-action="Login" asp-route-returnUrl="/Cart/Checkout"
                       class="inline-flex items-center justify-center rounded-md bg-slate-900 px-4 py-2 text-sm font-medium text-white hover:bg-slate-700 transition-colors">
                    Увійдіть щоб оформити 
                </a>
            }
        </div>
    }
</div>
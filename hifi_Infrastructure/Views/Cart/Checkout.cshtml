@{
    ViewData["Title"] = "Оформлення замовлення";
}

<div class="max-w-md space-y-6">
    <div class="flex items-center justify-between">
        <h1 class="text-2xl font-bold">Оформлення</h1>
        <a asp-action="Index" class="text-sm text-muted-foreground hover:text-foreground">← Кошик</a>
    </div>

    <div class="rounded-lg border bg-card p-6">
        <form method="post" class="space-y-4">
            @Html.AntiForgeryToken()
            <div class="space-y-1">
                <label class="text-sm font-medium">Покупець</label>
                <select name="Customerid" asp-items="ViewBag.Customerid"
                        class="flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-sm focus:outline-none focus:ring-1 focus:ring-ring"></select>
            </div>
            <button type="submit"
                    class="w-full inline-flex justify-center rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors">
                Підтвердити замовлення
            </button>
        </form>
    </div>
</div>
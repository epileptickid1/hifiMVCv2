@{
    ViewData["Title"] = "Оформлення замовлення";
}

<div class="max-w-md mx-auto space-y-6 mt-8">
    <div class="flex items-center justify-between">
        <h1 class="text-2xl font-bold">Оформлення</h1>
        <a asp-action="Index" class="inline-flex items-center justify-center rounded-md border px-4 py-2 text-sm text-muted-foreground hover:bg-accent hover:text-foreground"> Кошик</a>
    </div>

    <div class="rounded-lg border bg-card p-6 space-y-4">
        <div class="rounded-md bg-muted/50 px-4 py-3 text-sm space-y-1">
            <p class="font-medium">Ваше замовлення буде оформлено на акаунт:</p>
            <p class="text-muted-foreground">@User.Identity?.Name</p>
        </div>

        <form method="post" asp-action="Checkout" class="space-y-4">
            @Html.AntiForgeryToken()
            <p class="text-sm text-muted-foreground">
                Підтвердіть замовлення. Після підтвердження воно з'явиться у розділі "Мої замовлення".
            </p>
            <button type="submit"
                    class="w-full inline-flex justify-center rounded-md bg-slate-900 px-4 py-2 text-sm font-medium text-white hover:bg-slate-700 transition-colors">
                Підтвердити замовлення
            </button>
        </form>
    </div>
</div>
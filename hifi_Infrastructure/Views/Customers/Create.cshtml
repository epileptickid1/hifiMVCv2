@model hifiDomain.Model.Customer
@{
    ViewData["Title"] = "Додати покупця";
}

@if (!ViewData.ModelState.IsValid)
{
    <div class="bg-destructive">
        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
        {
            <p>@error.ErrorMessage</p>
        }
    </div>
}

<div class="max-w-md space-y-6">
    <div class="flex items-center justify-between">
        <h1 class="text-2xl font-bold">Новий покупець</h1>
        <a asp-action="Index" class="text-sm text-muted-foreground hover:text-foreground">← Назад</a>
    </div>
    <div class="rounded-lg border bg-card p-6">
        <form asp-action="Create" class="space-y-4">
            <div asp-validation-summary="ModelOnly" class="text-destructive text-sm"></div>
            <div class="space-y-1">
                <label asp-for="Name" class="text-sm font-medium"></label>
                <input asp-for="Name" class="flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-sm focus:outline-none focus:ring-1 focus:ring-ring" />
                <span asp-validation-for="Name" class="text-xs text-destructive"></span>
            </div>
            <div class="space-y-1">
                <label asp-for="Email" class="text-sm font-medium"></label>
                <input asp-for="Email" class="flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-sm focus:outline-none focus:ring-1 focus:ring-ring" />
            </div>
            <div class="space-y-1">
                <label asp-for="Phone" class="text-sm font-medium"></label>
                <input asp-for="Phone" class="flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-sm focus:outline-none focus:ring-1 focus:ring-ring" />
                <span asp-validation-for="Phone" class="text-xs text-destructive"></span>
            </div>
            <button type="submit"
                    class="w-full inline-flex justify-center rounded-md bg-blue-800 px-4 py-2 text-sm font-medium text-primary-foreground hover:-blue-600 transition-colors">
                Зберегти
            </button>
        </form>
    </div>
</div>

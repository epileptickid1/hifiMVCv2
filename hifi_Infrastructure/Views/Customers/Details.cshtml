@model hifi_Infrastructure.Models.User
@{
    ViewData["Title"] = "Деталі користувача";
    var roles = ViewBag.Roles as IList<string> ?? new List<string>();
}

<div class="max-w-md space-y-6">
    <div class="flex items-center justify-between">
        <h1 class="text-2xl font-bold">@Model.Name</h1>
        <a asp-action="Index" class="text-sm text-muted-foreground hover:text-foreground">← Назад</a>
    </div>

    <div class="rounded-lg border bg-card p-6 space-y-3 text-sm">
        <div class="grid grid-cols-2 gap-3">
            <span class="text-muted-foreground">Ім'я</span>
            <span class="font-medium">@Model.Name</span>
            <span class="text-muted-foreground">Email</span>
            <span>@Model.Email</span>
            <span class="text-muted-foreground">Ролі</span>
            <span class="flex gap-1 flex-wrap">
                @foreach (var role in roles)
                {
                    <span class="text-xs px-2 py-0.5 rounded-full border font-medium @(role == "Admin" ? "bg-slate-800 text-white border-slate-700" : "bg-indigo-100 text-indigo-800 border-indigo-200")">
                        @role
                    </span>
                }
            </span>
        </div>
    </div>

    <div class="flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id"
           class="inline-flex items-center justify-center rounded-md border px-4 py-2 text-sm font-medium hover:bg-accent transition-colors">
            Редагувати
        </a>
        <a asp-action="Delete" asp-route-id="@Model.Id"
           class="inline-flex items-center justify-center rounded-md border border-red-200 text-red-700 px-4 py-2 text-sm font-medium hover:bg-red-50 transition-colors">
            Видалити
        </a>
    </div>
</div>

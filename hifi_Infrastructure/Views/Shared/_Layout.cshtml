<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ВухаІндастріс</title>
    <link rel="stylesheet" href="~/css/output.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body class="min-h-screen bg-background font-sans antialiased">

    <header class="sticky top-0 z-50 w-full border-b bg-primary backdrop-blur">
        <div class="container mx-auto flex h-14 items-center px-4">
            <a asp-controller="Home" asp-action="Index">
                <img src="~/images/Вуха Індастріс.jpg"
                     class=" h-10 w-10 object-cover rounded-md" />
            </a>
            <nav class="flex items-center gap-1 text-sm ">
                
                <a asp-controller="Headphones" asp-action="Index"
                       class="px-3 py-2 rounded-md hover:bg-accent hover:text-accent-foreground transition-colors">
                    Навушники
                </a>
                <a asp-controller="Customers" asp-action="Index"
                       class="px-3 py-2 rounded-md hover:bg-accent hover:text-accent-foreground transition-colors">
                    Покупці
                </a>
                <a asp-controller="Orders" asp-action="Index"
                       class="px-3 py-2 rounded-md hover:bg-accent hover:text-accent-foreground transition-colors">
                    Замовлення
                </a>
                <a asp-controller="Internalpartsbrands" asp-action="Index"
                       class="px-3 py-2 rounded-md hover:bg-accent hover:text-accent-foreground transition-colors">
                    Компоненти
                </a>
                <a asp-controller="Cart" asp-action="Index"
                       class="px-3 py-2 rounded-md hover:bg-accent hover:text-accent-foreground transition-colors font-medium">
                     Кошик
                </a>
            </nav>
        </div>
    </header>

    <main class="container mx-auto px-4 py-8">
        @if (TempData["Error"] != null)
        {
            <div class="mb-4 rounded-lg border border-destructive/50 bg-destructive/10 px-4 py-3 text-destructive text-sm">
                @TempData["Error"]
            </div>
        }
        @RenderBody()
    </main>

    <footer class="border-t mt-auto py-4 text-center text-sm text-muted-foreground">
        &copy; 2039 — вухаіндастріс&#64;tuta.com &nbsp;|&nbsp;
        <a asp-controller="Home" asp-action="Privacy"
           class="underline underline-offset-4 hover:text-primary">Privacy</a>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
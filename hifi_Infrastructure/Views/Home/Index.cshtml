@model IEnumerable<hifiDomain.Model.Headphone>
@{
    ViewData["Title"] = "ВухаІндастріс";
}

<div class="space-y-6">
    <div>
        <h1 class="text-3xl font-bold tracking-tight">
            Каталог
        </h1>
        <p class="text-muted-foreground mt-1 text-sm">Навушники чужого виробництва</p>
    </div>

    <form method="get" class="flex max-w-xl gap-2">
        <input type="text" name="search"
               class="border-input flex h-9 w-full rounded-md border bg-transparent px-3 py-1 text-sm shadow-sm placeholder:text-muted-foreground focus:ring-ring focus:ring-1 focus:outline-none"
               placeholder="Пошук навушників..."
               value="@Context.Request.Query["search"]" />
        <button type="submit"
                class="text-primary-foreground inline-flex items-center justify-center rounded-md bg-sky-900 px-4 py-2 text-sm font-medium shadow transition-colors hover:bg-sky-600">
            Знайти
        </button>
        <a asp-action="Index"
               class="border-input bg-background inline-flex items-center justify-center rounded-md border px-4 py-2 text-sm font-medium shadow-sm transition-colors hover:bg-accent">
            Скинути
        </a>
    </form>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
        @foreach (var headphone in Model)
        {
            <div class="bg-card text-card-foreground flex flex-col overflow-hidden rounded-xl border shadow">
                <img src="~/images/@(headphone.Id).jpg"
                     class="h-60 w-full object-cover"
                     onerror="this.src='/images/default.jpg'" />
                <div class="flex flex-1 flex-col gap-2 p-4">
                    <h2 class="text-base leading-tight font-semibold">@headphone.Name</h2>
                    <p class="text-muted-foreground flex-1 text-sm">@headphone.Description</p>
                    <p class="text-lg font-bold">@headphone.Price ₴</p>
                    <p class="text-muted-foreground text-xs">
                        Матеріал: @headphone.Framematerial &nbsp;|&nbsp; Вага: @headphone.Weight г
                    </p>
                    <form method="get" asp-controller="Cart" asp-action="AddToCart" class="mt-2 flex gap-2">
                        <input type="hidden" name="id" value="@headphone.Id" />
                        <a asp-controller="Headphones" asp-action="Details" asp-route-id="@headphone.Id"
                               class="border-input bg-background inline-flex items-center justify-center rounded-md border px-3 py-1.5 text-xs font-medium transition-colors hover:bg-accent">
                            Деталі
                        </a>
                        <input type="number" name="quantity" value="1" min="1"
                               class="border-input w-16 rounded-md border bg-transparent px-2 py-1 text-center text-sm focus:ring-ring focus:ring-1 focus:outline-none" />
                        <button type="submit"
                                class="inline-flex flex-1 items-center justify-center rounded-md bg-slate-900 px-3 py-1.5 text-xs font-medium text-white transition-colors hover:bg-slate-700">
                            До кошика
                        </button>
                    </form>
                </div>
            </div>
        }
    </div>
</div>
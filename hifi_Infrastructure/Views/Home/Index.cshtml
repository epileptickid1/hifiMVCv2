@model IEnumerable<hifiDomain.Model.Headphone>

@{
    ViewData["Title"] = "HiFi Shop";
}

<div class="container mt-4">
    <h1 class="mb-4 text-center"> вухаіндастріс Shop</h1>
    <form method="get" class="mb-4">
        <div class="row g-2">
            <div class="col-md-8">
                <input type="text" name="search" class="form-control"
                       placeholder="Пошук навушників..."
                       value="@Context.Request.Query["search"]" />
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">Знайти</button>
            </div>
            <div class="col-md-2">
                <a asp-action="Index" class="btn btn-secondary w-100">Скинути</a>
            </div>
        </div>
    </form>
    <div class="row">
        @foreach (var headphone in Model)
        {

            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm">
                    <img src="~/images/@(headphone.Id).jpg"
                         class="card-img-top"
                         style="height:200px; object-fit:cover;"
                         onerror="this.src='/images/default.jpg'" />
                    <div class="card-body">
                        <h5 class="card-title">@headphone.Name</h5>
                        <p class="card-text text-muted">@headphone.Description</p>
                        <p class="card-text">
                            <strong>@headphone.Price ₴</strong>
                        </p>
                        <p class="card-text">
                            <small>Frame: @headphone.Framematerial | Weight: @headphone.Weight g</small>
                        </p>
                    </div>
                    <div class="card-footer">
                        <a asp-controller="Headphones" asp-action="Details"
                           asp-route-id="@headphone.Id"
                           class="btn btn-outline-primary btn-sm">Details</a>
                        <a asp-controller="Cart" asp-action="AddToCart"
                           asp-route-id="@headphone.Id"
                           class="btn btn-primary btn-sm">Add to Cart</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
@model hifiDomain.Model.Headphone
@{
    ViewData["Title"] = "Видалити навушник";
}

<div class="max-w-md space-y-6">
    <h1 class="text-2xl font-bold text-destructive">Видалити навушник?</h1>

    <div class="rounded-lg border border-destructive/30 bg-card p-6 space-y-3 text-sm">
        <div class="grid grid-cols-2 gap-2">
            <span class="text-muted-foreground">Назва</span><span class="font-medium">@Model.Name</span>
            <span class="text-muted-foreground">Ціна</span><span>@Model.Price ₴</span>
            <span class="text-muted-foreground">Матеріал</span><span>@Model.Framematerial</span>
            <span class="text-muted-foreground">Вага</span><span>@Model.Weight г</span>
        </div>
    </div>

    <form asp-action="Delete" class="flex gap-3">
        <input type="hidden" asp-for="Id" />
        <button type="submit"
                class="inline-flex items-center justify-center rounded-md bg-red-600 px-4 py-2 text-sm font-medium text-destructive-foreground hover:bg-red-700 transition-colors">
            Так, видалити
        </button>
        <a asp-action="Index"
               class="inline-flex items-center justify-center rounded-md border px-4 py-2 text-sm font-medium hover:bg-accent transition-colors">
            Скасувати
        </a>
    </form>
</div>
@model hifiDomain.Model.Headphone
@{
    ViewData["Title"] = "Додати навушник";
}

@if (!ViewData.ModelState.IsValid)
{
    <div class="bg-red-800">
        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
        {
            <p>@error.ErrorMessage</p>
        }
    </div>
}

<div class="max-w-md space-y-6">
    <div class="flex items-center justify-between">
        <h1 class="text-2xl font-bold">Новий навушник</h1>
        <a asp-action="Index" class="text-sm text-muted-foreground hover:text-foreground">← Назад</a>
    </div>
   
    <div class="rounded-lg border bg-card p-6">
       
        <form asp-action="Create" class="space-y-4">
            <div asp-validation-summary="ModelOnly" class="text-destructive text-sm"></div>
    
            <div class="space-y-1">
                <label asp-for="Name" class="text-sm font-medium"></label>
                <input asp-for="Name" class="flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-sm focus:outline-none focus:ring-1 focus:ring-ring" />
                <span asp-validation-for="Name" class="text-xs text-destructive"></span>
            </div>
            <div class="space-y-1">
                <label asp-for="Description" class="text-sm font-medium"></label>
                <input asp-for="Description" class="flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-sm focus:outline-none focus:ring-1 focus:ring-ring" />
            </div>
            <div class="space-y-1">
                <label asp-for="Price" class="text-sm font-medium"></label>
                <input asp-for="Price" class="flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-sm focus:outline-none focus:ring-1 focus:ring-ring" />
            </div>
            <div class="space-y-1">
                <label asp-for="Framematerial" class="text-sm font-medium"></label>
                <input asp-for="Framematerial" class="flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-sm focus:outline-none focus:ring-1 focus:ring-ring" />
            </div>
            <div class="space-y-1">
                <label asp-for="Weight" class="text-sm font-medium"></label>
                <input asp-for="Weight" class="flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-sm focus:outline-none focus:ring-1 focus:ring-ring" />
            </div>

            @{
                var brandList = ViewData["Internalpartsbrands"] as MultiSelectList;
            }
            <div class="space-y-1">
                <label class="text-sm font-medium">Внутрішні компоненти</label>
                <select name="selectedBrands" multiple asp-items="brandList"
                        class="flex w-full rounded-md border border-input bg-transparent px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-1 focus:ring-ring min-h-24">
                </select>
                <p class="text-xs text-muted-foreground">Ctrl+Click для вибору декількох</p>
            </div>

            <button type="submit"
                    class="w-full inline-flex justify-center rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors">
                Зберегти
            </button>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}